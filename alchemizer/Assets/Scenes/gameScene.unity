  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f183a0bf2bea9f04d8e20809da68b7bb, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::dialogueTrigger
  dialogue:
    dialogueID: test
    dialogueLines:
    - character:
        name: Custode del magazzino
        icon: {fileID: 8347362285229621783, guid: 1a6b42bf1bfbbdb4d91c2cc4501c7777, type: 3}
      line: Ah, sei qui per il registro delle consegne? Non posso chiudere il turno
        senza controllare l'ultima pagina.
    - character:
        name: Custode del magazzino
        icon: {fileID: 8347362285229621783, guid: 1a6b42bf1bfbbdb4d91c2cc4501c7777, type: 3}
      line: Ho sentito rumori nel corridoio e, per prudenza, l'ho riposto nella cassa
        accanto alla porta laterale.
    - character:
        name: Custode del magazzino
        icon: {fileID: 8347362285229621783, guid: 1a6b42bf1bfbbdb4d91c2cc4501c7777, type: 3}
      line: "\xC8 nella cassa accanto alla porta. Grazie per essere passato."
    oneTimeOnly: 1
    shown: 0
    isQuestDialogue: 1
    npc: {fileID: 0}
